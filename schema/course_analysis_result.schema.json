{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://classmate.local/schema/course_analysis_result.schema.json",
  "title": "CourseAnalysisResult",
  "description": "ClassMate v0.2 course-analysis model output. See spec §7.2 and §8.",
  "type": "object",
  "required": ["course_title", "summary", "segments", "quizzes", "review_plan"],
  "additionalProperties": false,
  "properties": {
    "course_title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ResultSegment" }
    },
    "quizzes": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/Quiz" }
    },
    "review_plan": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ReviewStep" }
    }
  },
  "$defs": {
    "ResultSegment": {
      "type": "object",
      "required": [
        "segment_id",
        "time_range",
        "corrected_text",
        "knowledge_points"
      ],
      "additionalProperties": false,
      "properties": {
        "segment_id": { "type": "string", "pattern": "^seg_[0-9]{3,}$" },
        "time_range": { "type": "string" },
        "corrected_text": { "type": "string" },
        "knowledge_points": {
          "type": "array",
          "items": { "$ref": "#/$defs/KnowledgePoint" }
        },
        "confusion_points": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "KnowledgePoint": {
      "type": "object",
      "required": [
        "kp_id",
        "name",
        "importance",
        "difficulty",
        "source_segment_id",
        "evidence_span",
        "explanation"
      ],
      "additionalProperties": false,
      "properties": {
        "kp_id": { "type": "string", "pattern": "^kp_[0-9]{3,}$" },
        "name": { "type": "string", "minLength": 1 },
        "importance": { "type": "integer", "minimum": 1, "maximum": 5 },
        "difficulty": { "type": "integer", "minimum": 1, "maximum": 5 },
        "source_segment_id": { "type": "string", "pattern": "^seg_[0-9]{3,}$" },
        "evidence_span": { "type": "string" },
        "explanation": { "type": "string" }
      }
    },
    "Quiz": {
      "type": "object",
      "required": [
        "quiz_id",
        "question",
        "options",
        "answer_index",
        "explanation",
        "source_segment_id",
        "related_kp_id",
        "evidence_span"
      ],
      "additionalProperties": false,
      "properties": {
        "quiz_id": { "type": "string", "pattern": "^q_[0-9]{3,}$" },
        "question": { "type": "string", "minLength": 1 },
        "options": {
          "type": "array",
          "minItems": 2,
          "maxItems": 6,
          "items": { "type": "string" }
        },
        "answer_index": { "type": "integer", "minimum": 0 },
        "explanation": { "type": "string" },
        "source_segment_id": { "type": "string", "pattern": "^seg_[0-9]{3,}$" },
        "related_kp_id": { "type": "string", "pattern": "^kp_[0-9]{3,}$" },
        "evidence_span": { "type": "string" }
      }
    },
    "ReviewStep": {
      "type": "object",
      "required": ["step_id", "duration_minutes", "task", "related_kp_ids"],
      "additionalProperties": false,
      "properties": {
        "step_id": { "type": "string", "pattern": "^rp_[0-9]{3,}$" },
        "duration_minutes": { "type": "integer", "minimum": 1, "maximum": 120 },
        "task": { "type": "string", "minLength": 1 },
        "related_kp_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^kp_[0-9]{3,}$" }
        },
        "reason": { "type": "string" }
      }
    }
  }
}
