{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://classmate.app/schema/course_analysis_result.v1.json",
  "title": "ClassMate model output contract (v1)",
  "description": "The JSON the model MUST return. The parser assigns stable ids and resolves each evidenceQuote to a character-offset EvidenceSpan in the named segment. Unresolvable quotes are dropped and make validation fail (which triggers fallback).",
  "type": "object",
  "additionalProperties": false,
  "required": ["knowledgePoints", "quizQuestions"],
  "properties": {
    "knowledgePoints": {
      "type": "array",
      "items": { "$ref": "#/definitions/knowledgePoint" }
    },
    "quizQuestions": {
      "type": "array",
      "items": { "$ref": "#/definitions/quizQuestion" }
    }
  },
  "definitions": {
    "importance": { "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
    "difficulty": { "enum": ["EASY", "MEDIUM", "HARD"] },
    "questionType": { "enum": ["CONCEPT_UNDERSTANDING", "JUDGMENT", "APPLICATION", "ERROR_ANALYSIS", "TRANSFER"] },
    "knowledgePoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "summary", "sourceSegmentId", "evidenceQuotes", "importance", "difficulty"],
      "properties": {
        "title": { "type": "string", "description": "Short concept name, e.g. 级数收敛与发散. NOT a copied paragraph." },
        "summary": { "type": "string", "description": "1-2 sentence learner-facing explanation." },
        "sourceSegmentId": { "type": "string", "description": "One of the given segment ids, e.g. seg_3." },
        "evidenceQuotes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "description": "A verbatim substring of the named segment's text." }
        },
        "importance": { "$ref": "#/definitions/importance" },
        "difficulty": { "$ref": "#/definitions/difficulty" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "quizQuestion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "stem", "options", "testedKnowledgePoints", "evidenceQuotes", "explanation", "difficulty"],
      "properties": {
        "type": { "$ref": "#/definitions/questionType" },
        "stem": { "type": "string" },
        "options": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["text", "isCorrect"],
            "properties": {
              "text": { "type": "string" },
              "isCorrect": { "type": "boolean" },
              "rationale": { "type": "string", "description": "Why this option is right/wrong (powers error analysis)." }
            }
          }
        },
        "testedKnowledgePoints": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "description": "Title of a knowledge point this question assesses." }
        },
        "evidenceQuotes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "explanation": { "type": "string" },
        "difficulty": { "$ref": "#/definitions/difficulty" }
      }
    }
  }
}
