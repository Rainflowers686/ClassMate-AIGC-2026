<?xml version="1.0" encoding="utf-8"?>
<!--
  Locks down backup/transfer. config.local.json lives in filesDir and must
  never leave the device — explicit exclude is belt-and-suspenders.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="config.local.json" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="config.local.json" />
    </device-transfer>
</data-extraction-rules>
