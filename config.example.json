{
  "_comment": "ClassMate model provider configuration TEMPLATE. Copy to config.local.json (git-ignored) and fill in real values locally. NEVER commit real credentials. See SECURITY.md.",
  "schemaVersion": 1,
  "activeProvider": "bluelm",
  "providers": {
    "bluelm": {
      "displayName": "vivo BlueLM (蓝心大模型)",
      "enabled": true,
      "baseUrl": "https://api-ai.vivo.com.cn",
      "model": "vivo-BlueLM-TB-Pro",
      "appId": "YOUR_BLUELM_APP_ID",
      "appKey": "YOUR_BLUELM_APP_KEY",
      "timeoutMs": 30000
    },
    "compatible": {
      "displayName": "OpenAI-compatible fallback endpoint",
      "enabled": false,
      "baseUrl": "https://YOUR_COMPATIBLE_ENDPOINT/v1",
      "model": "YOUR_MODEL_NAME",
      "apiKey": "YOUR_COMPATIBLE_API_KEY",
      "timeoutMs": 30000
    },
    "localFallback": {
      "displayName": "On-device deterministic fallback (no network)",
      "enabled": true,
      "note": "Bounded heuristic extractor. Safety net only — never the primary intelligence."
    }
  },
  "resolver": {
    "order": ["bluelm", "compatible", "localFallback"],
    "fallbackOnNon2xx": true,
    "fallbackOnParseError": true,
    "fallbackOnValidationError": true
  }
}
